<ul class="sidebar-menu bill-sidebar-static-menu">
    <li class="{{ activeRouteStrict('index') }}">
        <a href="{{ route('index') }}">
            <em class="fa fa-dashboard fa-fw"></em>
            <span>{{ 'dashboard'|_ }}</span>
        </a>
    </li>

    <li class="{{ activeRouteStrict('search.index') }} visible-xs hidden-sm hidden-md hidden-lg">
        <a href="{{ route('search.index') }}">
            <em class="fa fa-search fa-fw"></em>
            <span>{{ 'search'|_ }}</span>
        </a>
    </li>

    <li class="header text-uppercase">{{ 'financial_control'|_ }}</li>

    <li class="{{ activeRoutePartial('budgets') }}" id="budget-menu">
        <a href="{{ route('budgets.index') }}">
            <em class="fa fa-pie-chart fa-fw"></em>
            <span>{{ 'budgets'|_ }}</span>
        </a>
    </li>

    <li class="{{ activeRoutePartial('subscriptions') }}">
        <a href="{{ route('subscriptions.index') }}">
            <em class="fa fa-calendar-o fa-fw"></em>
            <span>{{ 'subscriptions'|_ }}</span>
        </a>
    </li>

    <li class="{{ activeRoutePartial('piggy-banks') }}">
        <a href="{{ route('piggy-banks.index') }}">
            <em class="fa fa-bullseye fa-fw"></em>
            <span>{{ 'piggyBanks'|_ }}</span>
        </a>
    </li>

    <li class="header text-uppercase">{{ 'accounting'|_ }}</li>

    <li class="{{ activeRoutePartial('transactions') }} treeview menu-open" id="transaction-menu">
        <a href="{{ route('transactions.index', ['all']) }}">
            <em class="fa fa-exchange fa-fw"></em>
            <span>{{ 'transactions'|_ }}</span>
        </a>

        <ul class="treeview-menu bill-sidebar-treeview-menu" style="display: block;">
            <li class="{{ activeRoutePartialObjectType('transactions', 'withdrawal') }}">
                <a href="{{ route('transactions.index', ['withdrawal']) }}">
                    <span>{{ 'expenses'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartialObjectType('transactions', 'deposit') }}">
                <a href="{{ route('transactions.index', ['deposit']) }}">
                    <span>{{ 'income'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartialObjectType('transactions', 'transfers') }}">
                <a href="{{ route('transactions.index', ['transfers']) }}">
                    <span>{{ 'transfers'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartial('daily-reconciliation') }}">
                <a href="{{ route('daily-reconciliation.index') }}">
                    <span>按天对账</span>
                </a>
            </li>
        </ul>
    </li>

    <li class="{{ activeRoutePartial('recurring') }} {{ activeRoutePartial('rules') }} treeview menu-open">
        <a href="#">
            <em class="fa fa-microchip fa-fw"></em>
            <span>{{ 'automation'|_ }}</span>
        </a>

        <ul class="treeview-menu bill-sidebar-treeview-menu" style="display: block;">
            <li class="{{ activeRoutePartial('rules') }}">
                <a href="{{ route('rules.index') }}">
                    <span>{{ 'rules'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartial('recurring') }}">
                <a href="{{ route('recurring.index') }}">
                    <span>{{ 'recurrences'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartial('bill-inbox') }}">
                <a href="{{ route('bill-inbox.index') }}">
                    <span>账单收件箱</span>
                </a>
            </li>
            {% if true == featuringWebhooks %}
                <li class="{{ activeRoutePartial('webhooks') }}">
                    <a href="{{ route('webhooks.index') }}">
                        <span>{{ 'webhooks'|_ }}</span>
                    </a>
                </li>
            {% endif %}
        </ul>
    </li>

    <li class="header text-uppercase">{{ 'others'|_ }}</li>

    <li class="{{ activeRoutePartial('accounts') }} treeview menu-open" id="account-menu">
        <a href="#">
            <em class="fa fa-credit-card fa-fw"></em>
            <span>{{ 'accounts'|_ }}</span>
        </a>

        <ul class="treeview-menu bill-sidebar-treeview-menu" style="display: block;">
            <li class="{{ activeRoutePartialObjectType('accounts', 'asset') }}">
                <a href="{{ route('accounts.index', ['asset']) }}">
                    <span>{{ 'asset_accounts'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartialObjectType('accounts', 'expense') }}">
                <a href="{{ route('accounts.index', ['expense']) }}">
                    <span>{{ 'expense_accounts'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartialObjectType('accounts', 'revenue') }}">
                <a href="{{ route('accounts.index', ['revenue']) }}">
                    <span>{{ 'revenue_accounts'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartialObjectType('accounts', 'liabilities') }}">
                <a href="{{ route('accounts.index', ['liabilities']) }}">
                    <span>{{ 'liabilities_accounts'|_ }}</span>
                </a>
            </li>
        </ul>
    </li>

    <li class="{{ activeRoutePartial('categories') }} {{ activeRoutePartial('tags') }} {{ activeRoutePartial('groups') }} treeview menu-open">
        <a href="#">
            <em class="fa fa-tags fa-fw"></em>
            <span>{{ 'classification'|_ }}</span>
        </a>

        <ul class="treeview-menu bill-sidebar-treeview-menu" style="display: block;">
            <li class="{{ activeRoutePartial('categories') }}">
                <a href="{{ route('categories.index') }}">
                    <span>{{ 'categories'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartial('tags') }}">
                <a href="{{ route('tags.index') }}">
                    <span>{{ 'tags'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartial('object-groups') }}">
                <a href="{{ route('object-groups.index') }}">
                    <span>{{ 'object_groups_menu_bar'|_ }}</span>
                </a>
            </li>
        </ul>
    </li>

    <li class="{{ activeRoutePartial('reports') }}" id="report-menu">
        <a href="{{ route('reports.index') }}"> {# relative route! #}
            <em class="fa fa-bar-chart fa-fw"></em>
            <span>{{ 'reports'|_ }}</span>
        </a>
    </li>


    {% if config('firefly.feature_flags.export') %}
        <li class="{{ activeRoutePartial('export') }}" id="report-menu">
            <a href="{{ route('export.index') }}">
                <em class="fa fa-upload fa-fw"></em>
                <span>{{ 'export_data_menu'|_ }}</span>
            </a>
        </li>
    {% endif %}

    <li class="{{ activeRoutePartial('administrations') }} {{ activeRoutePartial('setting') }} {{ activeRoutePartial('oauth') }} {{ activeRoutePartial('profile') }} {{ activeRoutePartial('preferences') }} {{ activeRoutePartial('currencies') }} {{ activeRoutePartial('exchange-rates') }} treeview menu-open"
        id="option-menu">
        <a href="#">
            <em class="fa fa-sliders fa-fw"></em>
            <span>{{ 'options'|_ }}</span>
        </a>

        <ul class="treeview-menu bill-sidebar-treeview-menu" style="display: block;">
            <li class="{{ activeRoutePartial('profile') }}">
                <a class="{{ activeRouteStrict('profile.index') }}" href="{{ route('profile.index') }}">
                    <span>{{ 'profile'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartial('oauth') }}">
                <a class="{{ activeRouteStrict('profile.oauth.index') }}" href="{{ route('profile.oauth.index') }}">
                    <span>{{ 'oauth_tokens'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartial('preferences') }}">
                <a class="{{ activeRouteStrict('preferences.index') }}"
                   href="{{ route('preferences.index') }}">
                    <span>{{ 'preferences'|_ }}</span>
                </a>
            </li>
            <li class="{{ activeRoutePartial('currencies') }}">
                <a class="{{ activeRoutePartial('currencies') }}" href="{{ route('currencies.index') }}">
                    <span>{{ 'currencies'|_ }}</span>
                </a>
            </li>
            {% if (fireflyiiiconfig('enable_exchange_rates', true)) %}
            <li class="{{ activeRoutePartial('exchange-rates') }}">
                <a class="{{ activeRoutePartial('exchange-rates') }}" href="{{ route('exchange-rates.index') }}">
                    <span>{{ 'menu_exchange_rates_index'|_ }}</span>
                </a>
            </li>
            {% endif %}
            <li class="{{ activeRoutePartial('administrations') }}">
                <a class="{{ activeRoutePartial('administration') }}" href="{{ route('administrations.index') }}">
                    <span>{{ 'administrations_index_menu'|_ }}</span>
                </a>
            </li>
            {% if hasRole('owner') %}
                <li class="{{ activeRoutePartial('settings') }}">
                    <a class="{{ activeRoutePartial('settings') }}" href="{{ route('settings.index') }}">
                        <span>{{ 'system_settings'|_ }}</span>
                    </a>
                </li>
            {% endif %}
        </ul>
    </li>

    {% if 'web' == authGuard %}
        <li>
            <a href="{{ route('logout') }}" class="logout-link">
                <em class="fa fa-sign-out fa-fw"></em>
                <span>{{ 'logout'|_ }}
                </span>
            </a>
        </li>
    {% endif %}
    {% if 'remote_user_guard' == authGuard and '' != logoutUrl %}
        <li>
            <a href="{{ logoutUrl }}">
                <em class="fa fa-sign-out fa-fw"></em>
                <span>{{ 'logout'|_ }}</span>
            </a>
        </li>
    {% endif %}
</ul>

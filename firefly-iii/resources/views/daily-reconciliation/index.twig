{% extends './layout/default' %}

{% block breadcrumbs %}
    {{ Breadcrumbs.render }}
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-12">
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">按天对账</h3>
                </div>
                <div class="box-body">
                    <form method="get" action="{{ route('daily-reconciliation.index') }}" class="form-inline">
                        <a class="btn btn-default" href="{{ route('daily-reconciliation.index', {date: prevDate}) }}">上一天</a>
                        <input class="form-control" type="date" name="date" value="{{ currentDate }}">
                        <button class="btn btn-primary" type="submit">查看</button>
                        <a class="btn btn-default" href="{{ route('daily-reconciliation.index', {date: nextDate}) }}">下一天</a>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-3 col-md-6 col-sm-6">
            <div class="small-box bg-green">
                <div class="inner"><h3>{{ summary.income }}</h3><p>收入</p></div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
            <div class="small-box bg-red">
                <div class="inner"><h3>{{ summary.expense }}</h3><p>支出</p></div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
            <div class="small-box bg-blue">
                <div class="inner"><h3>{{ summary.net }}</h3><p>净额</p></div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
            <div class="small-box bg-yellow">
                <div class="inner"><h3>{{ summary.count }}</h3><p>交易数</p></div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">{{ currentDate }} 当天交易</h3>
                </div>
                <div class="box-body no-padding">
                    <table class="table table-condensed table-striped daily-reconciliation-table">
                        <thead>
                        <tr>
                            <td colspan="8" class="no-margin-pagination">{{ groups.links('pagination.bootstrap-4')|raw }}</td>
                        </tr>
                        <tr>
                            <th>描述</th><th>分类</th><th>金额</th><th>来源账户</th><th>目标账户</th><th>流水余额</th><th>日期</th><th class="text-right">操作</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for group in groups %}
                            {% for transaction in group.transactions %}
                                {% set formId = 'daily-reconciliation-row-' ~ transaction.transaction_journal_id %}
                                {% set balanceAmount = transaction.source_balance_after ?? transaction.destination_balance_after %}
                                <tr>
                                    <td>
                                        <input class="form-control input-sm" form="{{ formId }}" name="description" type="text" value="{{ transaction.description }}" autocomplete="off">
                                    </td>
                                    <td>
                                        <input class="form-control input-sm" form="{{ formId }}" name="category_name" type="text" value="{{ transaction.category_name }}" autocomplete="off">
                                    </td>
                                    <td>
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-addon">{{ transaction.currency_symbol }}</span>
                                            <input class="form-control" form="{{ formId }}" name="amount" type="number" step="any" value="{{ transaction.amount|abs }}" autocomplete="off">
                                        </div>
                                    </td>
                                    <td>
                                        <input class="form-control input-sm" form="{{ formId }}" name="source_name" type="text" value="{{ transaction.source_account_name }}" autocomplete="off">
                                    </td>
                                    <td>
                                        <input class="form-control input-sm" form="{{ formId }}" name="destination_name" type="text" value="{{ transaction.destination_account_name }}" autocomplete="off">
                                    </td>
                                    <td class="text-right text-muted daily-reconciliation-balance">
                                        {% if balanceAmount is not null %}
                                            {{ formatAmountBySymbol(balanceAmount, transaction.currency_symbol, transaction.currency_decimal_places) }}
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td>
                                        <input class="form-control input-sm" form="{{ formId }}" name="transaction_date" type="date" value="{{ transaction.date.format('Y-m-d') }}">
                                    </td>
                                    <td class="text-right">
                                        <form id="{{ formId }}" method="post" action="{{ route('daily-reconciliation.update', [transaction.transaction_journal_id]) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token() }}">
                                            <input type="hidden" name="return_date" value="{{ currentDate }}">
                                            <button class="btn btn-xs btn-success" type="submit">保存</button>
                                            <a class="btn btn-xs btn-default" href="{{ route('transactions.show', [group.id]) }}">详情</a>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center text-muted">这一天没有交易。</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
    <style>
        .daily-reconciliation-table > tbody > tr > td {
            vertical-align: middle;
        }
        .daily-reconciliation-table .form-control {
            min-width: 110px;
        }
        .daily-reconciliation-table td:first-child .form-control {
            min-width: 220px;
        }
        .daily-reconciliation-balance {
            white-space: nowrap;
        }
    </style>
{% endblock %}

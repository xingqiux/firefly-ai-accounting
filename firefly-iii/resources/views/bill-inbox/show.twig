{% extends './layout/default' %}

{% block breadcrumbs %}
    {{ Breadcrumbs.render(Route.getCurrentRoute.getName, task) }}
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-7 col-md-12 col-sm-12 col-xs-12">
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">账单任务 #{{ task.id }}</h3>
                    <div class="box-tools pull-right">
                        <a class="btn btn-box-tool" href="{{ route('bill-inbox.index') }}">
                            <span class="fa fa-list fa-fw"></span> 返回列表
                        </a>
                    </div>
                </div>
                <div class="box-body no-padding">
                    <table class="table table-striped">
                        <tr>
                            <td style="width: 160px;">状态</td>
                            <td><strong>{{ task.status }}</strong></td>
                        </tr>
                        <tr>
                            <td>来源</td>
                            <td>{{ task.source }}{% if task.profile_id %} / {{ task.profile_id }}{% endif %}</td>
                        </tr>
                        <tr>
                            <td>摘要</td>
                            <td>{{ task.summary|default('-') }}</td>
                        </tr>
                        <tr>
                            <td>收到时间</td>
                            <td>{% if task.received_at %}{{ task.received_at.format('Y-m-d H:i:s') }}{% else %}-{% endif %}</td>
                        </tr>
                        {% if task.error_message %}
                            <tr>
                                <td>错误</td>
                                <td>
                                    {% if task.error_code %}<strong>{{ task.error_code }}</strong><br>{% endif %}
                                    {{ task.error_message }}
                                </td>
                            </tr>
                        {% endif %}
                    </table>
                </div>
                <div class="box-footer">
                    <form method="POST" action="{{ route('bill-inbox.retry', [task.id]) }}" style="display: inline-block;">
                        <input type="hidden" name="_token" value="{{ csrf_token() }}">
                        <button type="submit" class="btn btn-default">
                            <span class="fa fa-refresh fa-fw"></span> 重新排队
                        </button>
                    </form>
                    <form method="POST" action="{{ route('bill-inbox.ignore', [task.id]) }}" style="display: inline-block;">
                        <input type="hidden" name="_token" value="{{ csrf_token() }}">
                        <button type="submit" class="btn btn-warning">
                            <span class="fa fa-ban fa-fw"></span> 忽略任务
                        </button>
                    </form>
                </div>
            </div>

            {% if task.currentSecretChallenge %}
                <div class="box box-warning">
                    <div class="box-header with-border">
                        <h3 class="box-title">需要密码或验证码</h3>
                    </div>
                    <form method="POST" action="{{ route('bill-inbox.secret', [task.id]) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token() }}">
                        <div class="box-body">
                            <p>{{ task.currentSecretChallenge.prompt|default('请输入账单解密密码或验证码') }}</p>
                            <div class="form-group">
                                <label for="bill-secret-value">密码/验证码</label>
                                <input id="bill-secret-value" class="form-control" type="password" name="value" autocomplete="one-time-code" required>
                            </div>
                            <p class="text-muted">提交后系统只记录挑战已处理，不在任务表里保存明文密码。</p>
                        </div>
                        <div class="box-footer">
                            <button type="submit" class="btn btn-success">
                                <span class="fa fa-key fa-fw"></span> 提交并继续处理
                            </button>
                        </div>
                    </form>
                </div>
            {% endif %}

            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">邮件信息</h3>
                </div>
                <div class="box-body no-padding">
                    {% if task.mailMessage %}
                        <table class="table table-striped">
                            <tr><td style="width: 160px;">邮箱</td><td>{{ task.mailMessage.mailbox|default('-') }}</td></tr>
                            <tr><td>发件人</td><td>{{ task.mailMessage.from_address|default('-') }}</td></tr>
                            <tr><td>收件人</td><td>{{ task.mailMessage.to_address|default('-') }}</td></tr>
                            <tr><td>主题</td><td>{{ task.mailMessage.subject|default('-') }}</td></tr>
                            <tr><td>Message-ID</td><td>{{ task.mailMessage.message_id|default('-') }}</td></tr>
                            <tr><td>原始邮件</td><td>{{ task.mailMessage.raw_path|default('-') }}</td></tr>
                        </table>
                    {% else %}
                        <p class="text-muted" style="padding: 15px;">这个任务没有关联邮件记录。</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-5 col-md-12 col-sm-12 col-xs-12">
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">产物/附件</h3>
                </div>
                <div class="box-body no-padding">
                    {% if task.artifacts.count() == 0 %}
                        <p class="text-muted" style="padding: 15px;">暂无产物。</p>
                    {% else %}
                        <table class="table table-striped">
                            <thead>
                            <tr>
                                <th>类型</th>
                                <th>文件</th>
                                <th>加密</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for artifact in task.artifacts %}
                                <tr>
                                    <td>{{ artifact.kind }}</td>
                                    <td>
                                        {{ artifact.filename|default(artifact.path|default('-')) }}
                                        {% if artifact.path and artifact.filename %}
                                            <br><small class="text-muted">{{ artifact.path }}</small>
                                        {% endif %}
                                    </td>
                                    <td>{% if artifact.encrypted %}<span class="label label-warning">是</span>{% else %}<span class="label label-default">否</span>{% endif %}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}
                </div>
            </div>

            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">事件日志</h3>
                </div>
                <div class="box-body no-padding">
                    {% if task.events.count() == 0 %}
                        <p class="text-muted" style="padding: 15px;">暂无事件。</p>
                    {% else %}
                        <table class="table table-striped">
                            <thead>
                            <tr>
                                <th>时间</th>
                                <th>事件</th>
                                <th>说明</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for event in task.events %}
                                <tr>
                                    <td>{% if event.created_at %}{{ event.created_at.format('Y-m-d H:i') }}{% else %}-{% endif %}</td>
                                    <td>{{ event.event_type }}</td>
                                    <td>{{ event.message|default('-') }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

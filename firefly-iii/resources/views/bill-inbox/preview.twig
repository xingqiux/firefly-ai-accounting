{% extends "./layout/default" %}

{% block breadcrumbs %}
    {{ Breadcrumbs.render(Route.getCurrentRoute.getName, task, artifact) }}
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">{{ artifact.filename|default('账单附件') }}</h3>
                    <div class="box-tools pull-right">
                        <a class="btn btn-xs btn-default" href="{{ route('bill-inbox.show', [task.id]) }}">返回</a>
                        <a class="btn btn-xs btn-default" href="{{ route('bill-inbox.artifact.download', [artifact.id]) }}">
                            <span class="fa fa-download fa-fw"></span> 下载
                        </a>
                    </div>
                </div>
                <div class="box-body">
                    {% if content is not null %}
                        <pre style="max-height: 70vh; overflow: auto; white-space: pre-wrap;">{{ content }}</pre>
                    {% elseif tableRows|length > 0 %}
                        <div class="table-responsive" style="max-height: 70vh; overflow: auto;">
                            <table class="table table-condensed table-striped table-bordered">
                                <tbody>
                                {% for row in tableRows %}
                                    <tr>
                                        {% for cell in row %}
                                            <td>{{ cell }}</td>
                                        {% endfor %}
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% elseif previewArtifact.kind == 'pdf' %}
                        <iframe src="{{ route('bill-inbox.artifact.download', [artifact.id]) }}" style="width: 100%; height: 70vh; border: 0;"></iframe>
                    {% else %}
                        <p class="text-muted">该文件暂时无法直接预览，可以下载查看。</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

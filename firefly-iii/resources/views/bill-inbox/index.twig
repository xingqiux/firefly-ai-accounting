{% extends './layout/default' %}

{% block breadcrumbs %}
    {{ Breadcrumbs.render(Route.getCurrentRoute.getName) }}
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-12 col-sm-12 col-md-12">
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">账单收件箱</h3>
                    <div class="box-tools pull-right">
                        <a class="btn btn-box-tool" href="{{ route('bill-inbox.settings') }}">
                            <span class="fa fa-cog fa-fw"></span> 邮箱配置
                        </a>
                    </div>
                </div>
                <div class="box-body">
                    <div class="well well-sm" style="margin-bottom: 15px;">
                        <strong>邮箱配置状态</strong>
                        {% if mailboxStatus.enabled %}
                            <span class="label label-success">已启用</span>
                        {% else %}
                            <span class="label label-warning">未启用</span>
                        {% endif %}
                        <div class="row" style="margin-top: 10px;">
                            <div class="col-sm-3">
                                <small class="text-muted">邮箱</small><br>
                                {{ mailboxStatus.email|default('未配置') }}
                            </div>
                            <div class="col-sm-3">
                                <small class="text-muted">同步文件夹</small><br>
                                {{ mailboxStatus.folder|default('INBOX') }}
                            </div>
                            <div class="col-sm-3">
                                <small class="text-muted">内置渠道</small><br>
                                {% for channel in builtInChannels %}
                                    {{ channel.name }}{% if not loop.last %}<br>{% endif %}
                                {% endfor %}
                            </div>
                            <div class="col-sm-3">
                                <small class="text-muted">凭据</small><br>
                                {% if mailboxStatus.hasPassword %}
                                    应用密码已保存
                                {% else %}
                                    未保存应用密码
                                {% endif %}
                            </div>
                        </div>
                        {% if not mailboxStatus.enabled %}
                            <p class="text-warning" style="margin: 10px 0 0;">
                                邮箱配置已保存，但同步开关未启用。进入邮箱配置页勾选“启用账单邮箱同步”后，后续同步 worker 才会处理邮件。
                            </p>
                        {% else %}
                            <form method="POST" action="{{ route('bill-inbox.sync') }}" style="margin: 10px 0 0;">
                                <input type="hidden" name="_token" value="{{ csrf_token() }}">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <span class="fa fa-refresh fa-fw"></span> 立即同步
                                </button>
                            </form>
                        {% endif %}
                    </div>
                    <div class="btn-group" role="group">
                        <a class="btn btn-default {% if currentStatus == '' %}active{% endif %}" href="{{ route('bill-inbox.index') }}">全部</a>
                        {% for status, total in stats %}
                            <a class="btn btn-default {% if currentStatus == status %}active{% endif %}" href="{{ route('bill-inbox.index', {status: status}) }}">
                                {{ statusLabels[status]|default(status) }} <span class="badge">{{ total }}</span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
                <div class="box-body no-padding">
                    {% if tasks.count() == 0 %}
                        <p class="text-muted" style="padding: 15px;">暂无账单任务。配置邮箱后，内置渠道识别出的账单邮件会显示在这里。</p>
                    {% else %}
                        <form method="POST" action="{{ route('bill-inbox.archive-many') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token() }}">
                            <div class="table-responsive">
                            <table class="table table-hover table-striped">
                                <thead>
                                <tr>
                                    <th style="width: 36px;"></th>
                                    <th style="width: 80px;">ID</th>
                                    <th>状态</th>
                                    <th>来源</th>
                                    <th>邮件/摘要</th>
                                    <th>流水</th>
                                    <th>收到时间</th>
                                    <th>下一步</th>
                                    <th style="width: 150px;">操作</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for task in tasks %}
                                    <tr>
                                        <td><input type="checkbox" name="task_ids[]" value="{{ task.id }}"></td>
                                        <td>#{{ task.id }}</td>
                                        <td>
                                            {% if task.status == 'needs_secret' %}
                                                <span class="label label-warning">{{ statusLabels[task.status]|default(task.status) }}</span>
                                            {% elseif task.status == 'failed' or task.status == 'unknown' %}
                                                <span class="label label-danger">{{ statusLabels[task.status]|default(task.status) }}</span>
                                            {% elseif task.status == 'imported' or task.status == 'ready' %}
                                                <span class="label label-success">{{ statusLabels[task.status]|default(task.status) }}</span>
                                            {% elseif task.status == 'ignored' %}
                                                <span class="label label-default">{{ statusLabels[task.status]|default(task.status) }}</span>
                                            {% else %}
                                                <span class="label label-info">{{ statusLabels[task.status]|default(task.status) }}</span>
                                            {% endif %}
                                        </td>
                                        <td>{{ task.source }}{% if task.profile_id %}<br><small class="text-muted">{{ task.profile_id }}</small>{% endif %}</td>
                                        <td>
                                            <a href="{{ route('bill-inbox.show', [task.id]) }}">{{ task.summary|default(task.mailMessage.subject|default('无标题账单邮件')) }}</a>
                                            {% if task.mailMessage %}
                                                <br><small class="text-muted">{{ task.mailMessage.from_address }} → {{ task.mailMessage.to_address }}</small>
                                            {% endif %}
                                        </td>
                                        <td>{{ task.statementRows.count() }}</td>
                                        <td>
                                            {% if task.received_at %}
                                                {{ task.received_at.format('Y-m-d H:i') }}
                                            {% else %}
                                                -
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if task.currentSecretChallenge %}
                                                {{ task.currentSecretChallenge.prompt|default('请输入密码或验证码') }}
                                            {% elseif task.error_message %}
                                                {{ task.error_message }}
                                            {% else %}
                                                查看详情
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a class="btn btn-xs btn-default" href="{{ route('bill-inbox.show', [task.id]) }}">
                                                <span class="fa fa-search fa-fw"></span> 查看
                                            </a>
                                            <button class="btn btn-xs btn-default" type="submit" name="task_ids[]" value="{{ task.id }}">
                                                <span class="fa fa-archive fa-fw"></span> 归档
                                            </button>
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                            </div>
                            <div style="padding: 10px 15px;">
                                <button type="submit" class="btn btn-default btn-sm">
                                    <span class="fa fa-archive fa-fw"></span> 批量归档
                                </button>
                            </div>
                        </form>
                    {% endif %}
                </div>
                {% if tasks.count() > 0 %}
                    <div class="box-footer">
                        {{ tasks.links('pagination.bootstrap-4')|raw }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

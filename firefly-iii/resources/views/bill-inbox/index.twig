{% extends './layout/default' %}

{% block breadcrumbs %}
    {{ Breadcrumbs.render(Route.getCurrentRoute.getName) }}
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-12 col-sm-12 col-md-12">
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">账单收件箱</h3>
                    <div class="box-tools pull-right">
                        <a class="btn btn-box-tool" href="{{ route('bill-inbox.settings') }}">
                            <span class="fa fa-cog fa-fw"></span> 邮箱配置
                        </a>
                    </div>
                </div>
                <div class="box-body">
                    <div class="well well-sm" style="margin-bottom: 15px;">
                        <strong>邮箱配置状态</strong>
                        {% if mailboxStatus.enabled %}
                            <span class="label label-success">已启用</span>
                        {% else %}
                            <span class="label label-warning">未启用</span>
                        {% endif %}
                        <div class="row" style="margin-top: 10px;">
                            <div class="col-sm-3">
                                <small class="text-muted">邮箱</small><br>
                                {{ mailboxStatus.email|default('未配置') }}
                            </div>
                            <div class="col-sm-3">
                                <small class="text-muted">同步文件夹</small><br>
                                {{ mailboxStatus.folder|default('INBOX') }}
                            </div>
                            <div class="col-sm-3">
                                <small class="text-muted">内置渠道</small><br>
                                {% for channel in builtInChannels %}
                                    {{ channel.name }}{% if not loop.last %}<br>{% endif %}
                                {% endfor %}
                            </div>
                            <div class="col-sm-3">
                                <small class="text-muted">凭据</small><br>
                                {% if mailboxStatus.hasPassword %}
                                    应用密码已保存
                                {% else %}
                                    未保存应用密码
                                {% endif %}
                            </div>
                        </div>
                        {% if not mailboxStatus.enabled %}
                            <p class="text-warning" style="margin: 10px 0 0;">
                                邮箱配置已保存，但同步开关未启用。进入邮箱配置页勾选“启用账单邮箱同步”后，后续同步 worker 才会处理邮件。
                            </p>
                        {% endif %}
                    </div>
                </div>
                <div class="box-body no-padding">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead>
                            <tr>
                                <th>渠道</th>
                                <th>最近收到</th>
                                <th>需要验证码</th>
                                <th>待处理</th>
                                <th>处理失败</th>
                                <th>已解析</th>
                                <th>待存入</th>
                                <th>最近状态</th>
                                <th style="width: 90px;">操作</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for channel in sourceChannels %}
                                <tr>
                                    <td>
                                        <strong>{{ channel.name }}</strong>
                                    </td>
                                    <td>
                                        {% if channel.latest_received_at %}
                                            {{ channel.latest_received_at.format('Y-m-d H:i') }}
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="label {{ statusClasses.needs_secret|default('label-warning') }}">{{ channel.needs_secret_count }}</span>
                                    </td>
                                    <td>
                                        <span class="label {{ statusClasses.ready|default('label-warning') }}">{{ channel.todo_count }}</span>
                                    </td>
                                    <td>
                                        <span class="label {{ statusClasses.failed|default('label-danger') }}">{{ channel.failed_count }}</span>
                                    </td>
                                    <td>
                                        <span class="label {{ statusClasses.parsed|default('label-primary') }}">{{ channel.parsed_count }}</span>
                                    </td>
                                    <td>
                                        <span class="label {{ statusClasses.pending|default('label-warning') }}">{{ channel.pending_row_count }}</span>
                                    </td>
                                    <td>
                                        {% if channel.latest_status %}
                                            <span class="label {{ statusClasses[channel.latest_status]|default('label-info') }}">{{ statusLabels[channel.latest_status]|default(channel.latest_status) }}</span>
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td>
                                        <a class="btn btn-xs btn-primary" href="{{ route('bill-inbox.channel', {source: channel.source}) }}">
                                            <span class="fa fa-arrow-right fa-fw"></span> 进入
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% extends './layout/default' %}

{% block breadcrumbs %}
    {{ Breadcrumbs.render(Route.getCurrentRoute.getName, channel) }}
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-12 col-sm-12 col-md-12">
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">{{ channel.name }}</h3>
                    <div class="box-tools pull-right">
                        <a class="btn btn-box-tool" href="{{ route('bill-inbox.index') }}">
                            <span class="fa fa-arrow-left fa-fw"></span> 返回渠道
                        </a>
                        <a class="btn btn-box-tool" href="{{ route('bill-inbox.settings') }}">
                            <span class="fa fa-cog fa-fw"></span> 邮箱配置
                        </a>
                    </div>
                </div>
                <div class="box-body">
                    <div class="btn-group" role="group">
                        <a class="btn btn-default {% if currentStatus == '' %}active{% endif %}" href="{{ route('bill-inbox.channel', {source: channel.source}) }}">未归档</a>
                        {% for status, total in stats %}
                            <a class="btn btn-default {% if currentStatus == status %}active{% endif %}" href="{{ route('bill-inbox.channel', {source: channel.source, status: status}) }}">
                                {{ statusLabels[status]|default(status) }} <span class="label {{ statusClasses[status]|default('label-info') }}">{{ total }}</span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
                <div class="box-body no-padding">
                    {% if tasks.count() == 0 %}
                        <p class="text-muted" style="padding: 15px;">暂无{{ channel.name }}批次。</p>
                    {% else %}
                        {% for task in tasks %}
                            {% if task.currentSecretChallenge %}
                                <form id="bill-secret-{{ task.id }}" method="POST" action="{{ route('bill-inbox.secret', [task.id]) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token() }}">
                                    <input type="hidden" name="redirect_to" value="channel">
                                    <input type="hidden" name="source" value="{{ channel.source }}">
                                </form>
                            {% endif %}
                        {% endfor %}
                        <form method="POST" action="{{ route('bill-inbox.archive-many') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token() }}">
                            <input type="hidden" name="redirect_to" value="channel">
                            <input type="hidden" name="source" value="{{ channel.source }}">
                            <div class="table-responsive">
                                <table class="table table-hover table-striped">
                                    <thead>
                                    <tr>
                                        <th style="width: 36px;"></th>
                                        <th style="width: 80px;">ID</th>
                                        <th>状态</th>
                                        <th>来源</th>
                                        <th>批次</th>
                                        <th>附件</th>
                                        <th>流水</th>
                                        <th>收到时间</th>
                                        <th>下一步</th>
                                        <th style="width: 150px;">操作</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for task in tasks %}
                                        <tr>
                                            <td><input type="checkbox" name="task_ids[]" value="{{ task.id }}"></td>
                                            <td>#{{ task.id }}</td>
                                            <td>
                                                <span class="label {{ statusClasses[task.status]|default('label-info') }}">{{ statusLabels[task.status]|default(task.status) }}</span>
                                            </td>
                                            <td>{{ channel.name }}{% if task.profile_id %}<br><small class="text-muted">{{ task.profile_id }}</small>{% endif %}</td>
                                            <td>
                                                <a href="{{ route('bill-inbox.show', [task.id]) }}">{{ task.summary|default(task.mailMessage.subject|default('无标题账单邮件')) }}</a>
                                                {% if task.mailMessage %}
                                                    <br><small class="text-muted">{{ task.mailMessage.from_address }} → {{ task.mailMessage.to_address }}</small>
                                                {% endif %}
                                            </td>
                                            <td>{{ task.artifacts.count() }}</td>
                                            <td>{{ task.statementRows.count() }}</td>
                                            <td>
                                                {% if task.received_at %}
                                                    {{ task.received_at.format('Y-m-d H:i') }}
                                                {% else %}
                                                    -
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if task.currentSecretChallenge %}
                                                    {% set secretPrompt = task.currentSecretChallenge.prompt|default('请输入密码或验证码') %}
                                                    <div class="input-group input-group-sm" style="min-width: 260px; max-width: 420px;">
                                                        <input form="bill-secret-{{ task.id }}" class="form-control" type="password" name="value" autocomplete="one-time-code" required placeholder="{{ secretPrompt }}" title="{{ secretPrompt }}" aria-label="{{ secretPrompt }}">
                                                        <span class="input-group-btn">
                                                            <button form="bill-secret-{{ task.id }}" class="btn btn-warning btn-sm" type="submit">
                                                                <span class="fa fa-key fa-fw"></span> 提交
                                                            </button>
                                                        </span>
                                                    </div>
                                                {% elseif task.error_message %}
                                                    {{ task.error_message }}
                                                {% else %}
                                                    查看详情
                                                {% endif %}
                                            </td>
                                            <td>
                                                <a class="btn btn-xs btn-default" href="{{ route('bill-inbox.show', [task.id]) }}">
                                                    <span class="fa fa-search fa-fw"></span> 查看
                                                </a>
                                                <button class="btn btn-xs btn-default" type="submit" name="task_ids[]" value="{{ task.id }}">
                                                    <span class="fa fa-archive fa-fw"></span> 归档
                                                </button>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                            <div style="padding: 10px 15px;">
                                <button type="submit" class="btn btn-default btn-sm">
                                    <span class="fa fa-archive fa-fw"></span> 批量归档
                                </button>
                            </div>
                        </form>
                    {% endif %}
                </div>
                {% if tasks.count() > 0 %}
                    <div class="box-footer">
                        {{ tasks.links('pagination.bootstrap-4')|raw }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
